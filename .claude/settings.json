{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Bash(php artisan migrate:*)",
            "Bash(php artisan shopwired:audit-*)",
            "Bash(railway logs:*)",
            "Bash(railway service list:*)",
            "Bash(railway service:*)"
        ],
        "deny": [
            "Bash(*migrate:fresh*)",
            "Bash(*migrate:refresh*)",
            "Bash(*migrate:reset*)",
            "Bash(*db:wipe*)",
            "Bash(*queue:work*)",
            "Bash(*queue:listen*)",
            "Read(node_modules/**)",
            "Read(composer.lock)",
            "Read(package-lock.json)",
            "Read(yarn.lock)",
            "Read(pnpm-lock.yaml)",
            "Read(.idea/**)",
            "Read(_ide_helper.php)",
            "Read(_ide_helper_models.php)",
            "Read(.phpstorm.meta.php)",
            "Read(storage/framework/**)",
            "Read(public/build/**)",
            "Read(public/hot/**)",
            "Read(public/storage/**)"
        ]
    }
}
