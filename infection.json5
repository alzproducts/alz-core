{
    "$schema": "vendor/infection/infection/resources/schema.json",

    // Source code to mutate
    "source": {
        "directories": [
            "app/Domain",           // Business logic (highest priority for mutation testing)
            "app/Application",      // Use cases and orchestration
            "app/Infrastructure",   // API clients, repositories
            "app/Presentation"      // Controllers, commands, jobs, middleware
        ],
        "excludes": [
            "app/Providers"         // Service providers (framework wiring, not business logic)
        ]
    },

    // Test framework configuration (Pest runs on PHPUnit)
    "testFramework": "phpunit",

    // Performance optimization
    "timeout": 10,
    // threads: auto-detected based on CPU cores

    // Quality thresholds - Set for AI-generated tests
    // First AI test run: expect 65-75% MSI
    // After strengthening assertions: target 85%+
    "minMsi": 70,              // Minimum Mutation Score Indicator
    "minCoveredMsi": 80,       // MSI for covered code only

    // Logging
    "logs": {
        "text": "build/infection.log",
        "summary": "build/infection-summary.log",
        "json": "build/infection.json"
    },

    // AI-Optimized Mutators
    // @default includes all standard mutators that catch common AI test weaknesses:
    // - Equal/Identical mutators: Catch AI using == instead of ===
    // - TrueValue/FalseValue: Catch AI using assertTrue() instead of assertEquals()
    // - Not mutators: Catch AI using assertNotNull() instead of specific values
    // - Comparison mutators: Catch AI missing boundary checks
    //
    // See full list: vendor/infection/infection/src/Mutator/
    "mutators": {
        "@default": true
    }
}
