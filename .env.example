APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Laravel Sail (Docker) - Set to your user/group ID (run: id -u && id -g)
WWWUSER=1000
WWWGROUP=1000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

# Octane Configuration
OCTANE_SERVER=swoole
OCTANE_WORKERS=4
OCTANE_TASK_WORKERS=6
OCTANE_MAX_REQUESTS=500

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database - Local Development (Sail PostgreSQL)
# Uses local PostgreSQL container for fast, isolated development
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=alz_core
DB_USERNAME=sail
DB_PASSWORD=password
DB_SSLMODE=disable

# How to Test Supabase Connection Locally
# ---------------------------------------
# Supabase is used in production (shared with Next.js frontend).
# To verify connectivity from local development:
#
# 1. Get credentials from Supabase Dashboard:
#    → Project Settings → Database → Connection String
#
# 2. Temporarily update .env with Supabase credentials:
#    DB_HOST=db.your-project.supabase.co
#    DB_DATABASE=postgres
#    DB_USERNAME=postgres
#    DB_PASSWORD=<your-supabase-password>
#    DB_SSLMODE=require
#
# 3. Verify connection:
#    ./vendor/bin/sail artisan db:show
#
# 4. Run database connectivity tests:
#    ./vendor/bin/sail artisan test --filter=DatabaseConnectivityTest
#
# 5. Switch back to local database (restore settings above)
#
# IMPORTANT: Never commit Supabase credentials to version control!

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 Storage Configuration
# Used for: product feeds, image optimization, exports
# Setup: IAM → Users → Create user with S3 permissions
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-2
AWS_BUCKET=alz-core-storage

# DooFinder Product Feed Configuration
# Transforms Google Ads feed for DooFinder site search
# Generate GUID once: php -r "echo bin2hex(random_bytes(16));"
DOOFINDER_FEED_GUID=

# Supabase Authentication
# Get this from Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=
#
# Local Development Auth Bypass (optional)
# Allows testing protected endpoints without a real Supabase JWT
# Usage: curl -H "X-Local-Bypass: <secret>" http://localhost:8000/api/...
# Only works when: APP_ENV=local AND request from 127.0.0.1/::1
SUPABASE_LOCAL_BYPASS_SECRET=
SUPABASE_LOCAL_TEST_EMAIL=

# User Email Aliases
# Maps alternate email addresses to primary for external service lookups
EMAIL_TOM_MAIN=
EMAIL_TOM_SECONDARY=

# Horizon Dashboard (Queue Monitoring)
# Access at: http://localhost:8000/horizon
# Use any credentials for local development (Basic HTTP Auth)
HORIZON_USER=local-admin
HORIZON_PASSWORD=local-password

# Helpscout API Configuration
# Get credentials from: Help Scout Dashboard → My Apps → Your App
# Docs: https://developer.helpscout.com/mailbox-api/overview/authentication/
#
# Modern API (Recommended - OAuth 2.0 Client Credentials)
HS_AUTH_TYPE=client_credentials
HS_APP_ID=
HS_APP_SECRET=
#
# Legacy API (Deprecated - Use only if required)
# HS_AUTH_TYPE=legacy_token
# HS_CLIENT_ID=
# HS_API_KEY=

# Reviews.io API Configuration
# Get credentials from: Reviews.io Dashboard → Settings → API
# Docs: https://api.reviews.co.uk/
REVIEWSIO_API_KEY=
REVIEWSIO_STORE=
# Optional: Advanced configuration (defaults shown)
# REVIEWSIO_TIMEOUT=30
# REVIEWSIO_RETRY_TIMES=3
# REVIEWSIO_RETRY_DELAY=100

# Google Ads API Configuration
# Integrates daily Google Ads campaign metrics with Mixpanel analytics
# Setup: https://console.cloud.google.com/apis/credentials
# Docs: https://developers.google.com/google-ads/api/docs/start
#
# 1. Create OAuth 2.0 Client ID (Web application)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
#
# 2. Generate refresh token using OAuth2 flow
#    (See .ai/docs/plans/2025-11-19_30-mixpanel-ad-spend-integration.md for setup)
GOOGLE_ADS_REFRESH_TOKEN=
#
# 3. Get from Google Ads MCC (Manager Account)
GOOGLE_ADS_DEVELOPER_TOKEN=
#
# 4. Your Google Ads Customer ID (format: 1234567890 without hyphens)
GOOGLE_ADS_CUSTOMER_ID=
#
# 5. Login customer ID (if using MCC - usually same as CUSTOMER_ID)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Mixpanel Analytics Configuration
# Receives transformed Google Ads spend data for attribution tracking
# Setup: https://mixpanel.com → Project Settings → Service Accounts
# Docs: https://developer.mixpanel.com/reference/overview
#
# Service Account username (create in: Project Settings → Service Accounts)
MIXPANEL_SERVICE_ACCOUNT_USERNAME=
#
# Service Account password (generated when creating Service Account)
MIXPANEL_SERVICE_ACCOUNT_PASSWORD=
#
# Mixpanel Project ID (numeric, found in: Project Settings)
MIXPANEL_PROJECT_ID=
#
# API endpoint (optional - defaults to https://api-eu.mixpanel.com)
MIXPANEL_BASE_URL=https://api-eu.mixpanel.com
#
# Lookup table ID for UTM campaign data (create in: Data Management → Lookup Tables)
MIXPANEL_UTM_CAMPAIGN_LOOKUP_TABLE_ID=

# Shopwired E-commerce API Configuration
# For order/product sync integration with Shopwired platform
# Docs: https://shopwired.readme.io/docs/getting-started
#
# API Key (HTTP Basic Auth username)
SHOPWIRED_API_KEY=
#
# API Secret (HTTP Basic Auth password)
SHOPWIRED_API_SECRET=

# Linnworks Inventory Management API Configuration
# For inventory sync with Linnworks order management system
# Docs: https://apidocs.linnworks.net/
#
# OAuth Application ID (from: Linnworks → Settings → API → Applications)
LINNWORKS_APPLICATION_ID=
#
# OAuth Application Secret
LINNWORKS_APPLICATION_SECRET=
#
# Installation Token (user-specific, generated when authorizing application)
LINNWORKS_INSTALLATION_TOKEN=

# Bing Ads (Microsoft Advertising) API Configuration
# Integrates daily Bing Ads campaign metrics with Mixpanel analytics
# Setup: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
# Docs: https://learn.microsoft.com/en-us/advertising/guides/
#
# 1. Register Azure AD Application (Account types: Any org + personal)
BING_ADS_CLIENT_ID=
BING_ADS_CLIENT_SECRET=
#
# 2. Generate refresh token using OAuth2 flow (scope: offline_access msads.manage)
BING_ADS_REFRESH_TOKEN=
#
# 3. Get from Microsoft Advertising Developer Portal
#    https://developers.bingads.microsoft.com/Account
BING_ADS_DEVELOPER_TOKEN=
#
# 4. Account ID and Customer ID from Microsoft Advertising UI
BING_ADS_ACCOUNT_ID=
BING_ADS_CUSTOMER_ID=
#
# 5. Environment: 'Production' or 'Sandbox' (default: Production)
# BING_ADS_ENVIRONMENT=Production

VITE_APP_NAME="${APP_NAME}"
