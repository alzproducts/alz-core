APP_NAME="ALZ Core"
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://your-app.up.railway.app

# ==============================================================================
# Docker / Railway Configuration
# ==============================================================================

# PORT - Railway automatically injects this (DO NOT SET MANUALLY)
# Docker uses this for dynamic port binding
# Default: 8000 (used if PORT not set)
# PORT=

# Auto-run database migrations on container startup
# Set to "true" to enable automatic migrations (⚠️ use with caution)
# Recommended: false (run migrations manually via Railway CLI)
AUTO_MIGRATE=false

# Skip database connectivity check on startup
# Set to "true" if database check causes startup delays
# Default: false (recommended - ensures DB is ready before starting)
SKIP_DB_CHECK=false

# ==============================================================================
# Octane Configuration
# ==============================================================================
OCTANE_SERVER=swoole

# Worker configuration (auto-tuned based on CPU cores if not set)
# Railway Free: 2 workers, Railway Pro: 4-8 workers depending on plan
OCTANE_WORKERS=4
OCTANE_TASK_WORKERS=6

# Max requests before worker restart (prevents memory leaks)
# Lower = more frequent restarts, higher = better performance
OCTANE_MAX_REQUESTS=500

OCTANE_HTTPS=true

# Octane port (automatically set to $PORT by docker-entrypoint.sh)
# OCTANE_PORT=

LOG_CHANNEL=stderr
LOG_LEVEL=info

# Database (Supabase PostgreSQL - Shared with Next.js Frontend)
# Get credentials from Supabase Dashboard → Project Settings → Database
# Connection String format: postgres://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=require

# Redis (REQUIRED: Always use strong password in production - 32+ characters)
# Use Railway's managed Redis with built-in authentication
REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=6379

# Cache & Queue
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

# Horizon Dashboard Authentication (Queue Monitoring)
# Access at: https://your-app.up.railway.app/horizon
# REQUIRED: Set strong credentials (32+ characters recommended)
# Uses HTTP Basic Authentication over HTTPS
HORIZON_USER=
HORIZON_PASSWORD=

# Supabase Authentication
# Get this from Supabase Dashboard → Settings → API → JWT Secret
# REQUIRED: This must match your Supabase project's JWT secret
SUPABASE_JWT_SECRET=

# Telescope (disable in production)
TELESCOPE_ENABLED=false
