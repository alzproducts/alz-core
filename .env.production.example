APP_NAME="ALZ Core"
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://your-app.up.railway.app

LOG_CHANNEL=stderr
LOG_LEVEL=info

# Database (Supabase PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=

# Redis
REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=6379

# Cache & Queue
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database

# Horizon Authentication
HORIZON_USER=
HORIZON_PASSWORD=

# Telescope (disable in production)
TELESCOPE_ENABLED=false