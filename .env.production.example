APP_NAME="ALZ Core"
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://your-app.up.railway.app

LOG_CHANNEL=stderr
LOG_LEVEL=info

# Database (Supabase PostgreSQL - Shared with Next.js Frontend)
# Get credentials from Supabase Dashboard → Project Settings → Database
# Connection String format: postgres://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=require

# Redis (REQUIRED: Always use strong password in production - 32+ characters)
# Use Railway's managed Redis with built-in authentication
REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=6379

# Cache & Queue
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

# Horizon Authentication
HORIZON_USER=
HORIZON_PASSWORD=

# Supabase Authentication
# Get this from Supabase Dashboard → Settings → API → JWT Secret
# REQUIRED: This must match your Supabase project's JWT secret
SUPABASE_JWT_SECRET=

# Telescope (disable in production)
TELESCOPE_ENABLED=false
