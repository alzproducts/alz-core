<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         failOnDeprecation="false"
         failOnPhpunitDeprecation="false"
         failOnNotice="true"
         failOnWarning="true"
>
    <testsuites>
        <!-- Layer-based test suites (Clean Architecture) -->
        <testsuite name="Domain">
            <directory>tests/Unit/Domain</directory>
        </testsuite>
        <testsuite name="Application">
            <directory>tests/Unit/Application</directory>
            <directory>tests/Feature/Application</directory>
        </testsuite>
        <testsuite name="Infrastructure">
            <directory>tests/Unit/Infrastructure</directory>
            <directory>tests/Feature/Infrastructure</directory>
        </testsuite>
        <testsuite name="Presentation">
            <directory>tests/Feature/Presentation</directory>
            <directory>tests/Unit/Presentation</directory>
        </testsuite>
        <!-- Integration tests — require live DB (Supabase); fail = sync local + prod -->
        <!-- CI skips this suite via the `exclude-group=integration` Pest flag; local make test runs it -->
        <testsuite name="Integration">
            <directory>tests/Integration</directory>
        </testsuite>
        <!-- Supporting test suites -->
        <!-- Temporarily disabled: Google Ads SDK PHP 8.4 deprecation - see todo.php
        <testsuite name="Architecture">
            <file>tests/ArchitectureTest.php</file>
        </testsuite>
        -->
        <testsuite name="Providers">
            <directory>tests/Unit/Providers</directory>
        </testsuite>
        <testsuite name="DevTools">
            <directory>tests/Unit/DevTools</directory>
        </testsuite>
    </testsuites>
    <coverage>
        <report>
            <clover outputFile="build/logs/clover.xml"/>
        </report>
    </coverage>
    <source ignoreIndirectDeprecations="true">
        <include>
            <directory>app</directory>
        </include>
        <exclude>
            <directory>app/DevTools/GitHooks</directory>
            <file>app/Models/User.php</file>
            <directory suffix="ServiceProvider.php">./app</directory>
            <directory suffix="Exception.php">./app</directory>
            <directory suffix="Factory.php">./app</directory>
            <file>app/Domain/Review/Rating.php</file>
            <!-- Domain Events are data carriers with no logic (TestingStrategy.md) -->
            <directory suffix="Event.php">./app/Domain</directory>
            <!-- SOAP transport - tested via smoke tests, mocking is brittle -->
            <file>app/Infrastructure/BingAds/BingAdsTransport.php</file>
            <!-- Orchestration UseCases - pure delegation, no testable business logic (TestingStrategy.md) -->
            <file>app/Application/Shopwired/UseCases/SyncProductsUseCase.php</file>
            <file>app/Application/Shopwired/UseCases/SyncCustomFieldsUseCase.php</file>
            <file>app/Application/Shopwired/UseCases/ReconcileProductsUseCase.php</file>
            <!-- Simple result value objects - minimal logic, type system handles structure -->
            <file>app/Application/ValueObjects/ReconcileResult.php</file>
            <!-- Pure delegation UseCases - no branching logic (TestingStrategy.md) -->
            <file>app/Application/ContactSubmission/UseCases/SubmitContactFormUseCase.php</file>
            <!-- Simple result value objects - minimal logic -->
            <file>app/Application/ContactSubmission/Results/SubmitContactFormResult.php</file>
        </exclude>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <env name="HELPSCOUT_SYSTEM_USER_ID" value="999999"/>
    </php>
    <extensions>
        <bootstrap class="DG\BypassFinals\PHPUnitExtension"/>
    </extensions>
</phpunit>
