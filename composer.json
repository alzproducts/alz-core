{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "alzproducts/alz-core",
    "type": "project",
    "description": "Backend engine for AlzAdmin platform - handles sync, webhooks, and background processing",
    "keywords": ["laravel", "framework", "webhooks", "background-jobs"],
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "ext-dom": "*",
        "ext-pcntl": "*",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "ext-simplexml": "*",
        "ext-soap": "*",
        "ext-swoole": "*",
        "ext-tokenizer": "*",
        "ext-xmlreader": "*",
        "ext-zip": "*",
        "firebase/php-jwt": "*",
        "giggsey/libphonenumber-for-php-lite": "^9.0",
        "googleads/google-ads-php": "^31.1",
        "helpscout/api-laravel": "^2.1",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.35",
        "laravel/octane": "^2.13",
        "laravel/sanctum": "^4.2",
        "laravel/tinker": "^2.10.1",
        "league/flysystem-aws-s3-v3": "^3.0",
        "microsoft/bingads": "^13.0",
        "predis/predis": "^3.2",
        "sentry/sentry-laravel": "^4.0",
        "spatie/laravel-data": "^4.18",
        "theiconic/name-parser": "^1.2",
        "webmozart/assert": "^1.11"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "~3.5.4",
        "deptrac/deptrac": "^4.2",
        "dg/bypass-finals": "^1.9",
        "driftingly/rector-laravel": "^2.1",
        "fakerphp/faker": "^1.23",
        "igorsgm/laravel-git-hooks": "^2.0",
        "infection/infection": "^0.32",
        "kcs/phpstan-strict-rules": "^2.1",
        "larastan/larastan": "^3.0",
        "laravel/pail": "^1.2",
        "laravel/pint": "^1.24",
        "laravel/telescope": "^5.14",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "nunomaduro/phpinsights": "^2.13",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phparkitect/phparkitect": "^0.7.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-webmozart-assert": "^2.0",
        "phpunit/phpunit": "^12.0",
        "psalm/plugin-laravel": "^3.0",
        "react/http": "^1.11",
        "react/socket": "^1.17",
        "rector/rector": "^2.2",
        "shipmonk/phpstan-rules": "^4.2",
        "spaze/phpstan-disallowed-calls": "^4.7",
        "staabm/phpstan-todo-by": "^0.3.3",
        "symplify/phpstan-rules": "^14.9",
        "tightenco/tlint": "*",
        "tomasvotruba/cognitive-complexity": "^1.0",
        "tomasvotruba/type-coverage": "^2.1",
        "vimeo/psalm": "^6.14"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@ide-helper"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "lint": "make lint",
        "lint:full": "make lint-full",
        "fix": "make fix",
        "pint": "make pint",
        "pint:test": "make pint-test",
        "analyse": "make analyse",
        "insights": "make insights",
        "phparkitect": "make phparkitect",
        "stan": "@analyse",
        "check": "make check",
        "test": "make test",
        "test:feature": "make test-feature",
        "test:coverage": "make test-coverage",
        "test:domain": "make test-domain",
        "test:domain:coverage": "make test-domain-coverage",
        "test:app": "make test-app",
        "test:app:coverage": "make test-app-coverage",
        "infection": "make infection",
        "infection:strict": "make infection-strict",
        "infection:fast": "make infection-fast",
        "infection:incremental": "make infection-incremental",
        "infection:ci": "make infection-ci",
        "mutate:domain": "make mutate-domain",
        "mutate:app": "make mutate-app",
        "pest:mutate": "make pest-mutate",
        "test:ai": "make test-ai",
        "test:mutate": "make test-mutate",
        "check:full": "make check-full",
        "ide-helper": "make ide-helper",
        "rector": "make rector",
        "rector:dry-run": "make rector-dry-run",
        "refactor": "make refactor",
        "psalm": "make psalm",
        "psalm:ci": "make psalm-ci",
        "psalm:baseline": "make psalm-baseline"
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "infection/extension-installer": true
        },
        "platform": {
            "php": "8.4.3"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
