{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "alzproducts/alz-core",
    "type": "project",
    "description": "Backend engine for AlzAdmin platform - handles sync, webhooks, and background processing",
    "keywords": ["laravel", "framework", "webhooks", "background-jobs"],
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.35",
        "laravel/sanctum": "^4.2",
        "laravel/tinker": "^2.10.1",
        "predis/predis": "^3.2",
        "webmozart/assert": "^1.11"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6",
        "driftingly/rector-laravel": "^2.1",
        "fakerphp/faker": "^1.23",
        "igorsgm/laravel-git-hooks": "^2.0",
        "infection/infection": "^0.31.7",
        "larastan/larastan": "^3.0",
        "laravel/pail": "^1.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.46",
        "laravel/telescope": "^5.14",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "nunomaduro/phpinsights": "^2.13",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phparkitect/phparkitect": "^0.6.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-mockery": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-webmozart-assert": "^2.0",
        "phpunit/phpunit": "^11.5.3",
        "rector/rector": "^2.2",
        "shipmonk/phpstan-rules": "^4.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@ide-helper"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "lint": [
            "@pint:test",
            "@analyse",
            "@phparkitect"
        ],
        "lint:full": [
            "@pint:test",
            "@analyse",
            "@insights",
            "@phparkitect"
        ],
        "fix": [
            "Composer\\Config::disableProcessTimeout",
            "@php vendor/bin/pint --parallel"
        ],
        "pint": [
            "Composer\\Config::disableProcessTimeout",
            "@php vendor/bin/pint --parallel"
        ],
        "pint:test": [
            "Composer\\Config::disableProcessTimeout",
            "@php vendor/bin/pint --test --parallel"
        ],
        "analyse": [
            "Composer\\Config::disableProcessTimeout",
            "@php -d xdebug.mode=off vendor/bin/phpstan analyse"
        ],
        "insights": [
            "Composer\\Config::disableProcessTimeout",
            "@php -d xdebug.mode=off vendor/bin/phpinsights --no-interaction"
        ],
        "phparkitect": [
            "Composer\\Config::disableProcessTimeout",
            "@php vendor/bin/phparkitect check"
        ],
        "stan": "@analyse",
        "check": [
            "@lint:full",
            "@test"
        ],
        "test": [
            "Composer\\Config::disableProcessTimeout",
            "@php vendor/bin/pest --parallel --fail-on-deprecation"
        ],
        "test:coverage": [
            "Composer\\Config::disableProcessTimeout",
            "@php vendor/bin/pest --coverage --min=80"
        ],
        "infection": [
            "Composer\\Config::disableProcessTimeout",
            "@php -d xdebug.mode=off vendor/bin/infection --no-progress --show-mutations"
        ],
        "infection:strict": [
            "Composer\\Config::disableProcessTimeout",
            "@php -d xdebug.mode=off vendor/bin/infection --no-progress --show-mutations --min-msi=70 --min-covered-msi=80"
        ],
        "infection:fast": [
            "Composer\\Config::disableProcessTimeout",
            "@php -d xdebug.mode=off vendor/bin/pest --log-junit=build/logs/junit.xml --coverage-xml=build/logs/coverage-xml --coverage-clover=build/logs/clover.xml",
            "@php -d xdebug.mode=off vendor/bin/infection --coverage=build/logs --skip-initial-tests --no-progress --show-mutations --min-msi=70 --min-covered-msi=80"
        ],
        "infection:incremental": [
            "Composer\\Config::disableProcessTimeout",
            "@php -d xdebug.mode=off vendor/bin/infection --git-diff-lines --git-diff-base=main --no-progress --show-mutations --min-msi=70 --min-covered-msi=80"
        ],
        "infection:ci": [
            "Composer\\Config::disableProcessTimeout",
            "@php -d xdebug.mode=off vendor/bin/infection --no-progress --logger-github --min-msi=70 --min-covered-msi=80"
        ],
        "pest:mutate": [
            "Composer\\Config::disableProcessTimeout",
            "@php -d xdebug.mode=off vendor/bin/pest --mutate --everything --covered-only --min=90"
        ],
        "test:ai": [
            "Composer\\Config::disableProcessTimeout",
            "@test",
            "@infection"
        ],
        "test:mutate": [
            "Composer\\Config::disableProcessTimeout",
            "@test",
            "@pest:mutate",
            "@infection:strict"
        ],
        "check:full": [
            "@lint:full",
            "@test",
            "@infection"
        ],
        "ide-helper": [
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:models --nowrite",
            "@php artisan ide-helper:meta"
        ],
        "rector": [
            "Composer\\Config::disableProcessTimeout",
            "@php -d xdebug.mode=off vendor/bin/rector process"
        ],
        "rector:dry-run": [
            "Composer\\Config::disableProcessTimeout",
            "@php -d xdebug.mode=off vendor/bin/rector process --dry-run"
        ],
        "refactor": [
            "@rector",
            "@fix"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "infection/extension-installer": true
        },
        "platform": {
            "php": "8.4.0"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
