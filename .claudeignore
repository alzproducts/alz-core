# Dependencies & build artifacts
# Note: vendor/ intentionally NOT ignored — needed for framework constraint verification.
# Explore agent has instructions to avoid crawling it unless asked.
node_modules/
public/build/
public/hot/
public/storage/
build/

# Framework generated (cache, sessions, views)
storage/framework/
storage/pail/
bootstrap/cache/

# IDE & editor
.idea/
.fleet/
.nova/
.vscode/
.zed/
_ide_helper.php
_ide_helper_models.php
.phpstorm.meta.php

# Test & lint caches
.phpunit.cache/
.phpunit.result.cache
.rector/
.rector-cache/
.deptrac.cache
coverage-report/

# Logs — block noisy ones, keep Laravel/Octane logs accessible for debugging
*.log
!storage/logs/*.log

# Compiled/minified assets
*.min.js
*.min.css
*.map

# Lock files (large, not useful for code understanding)
composer.lock
package-lock.json
yarn.lock
pnpm-lock.yaml
